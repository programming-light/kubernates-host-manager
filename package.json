{
  "name": "k8s-hosting-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant Kubernetes hosting platform (Vercel/Hostinger hybrid)",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "db:migrate": "cd packages/backend && pnpm prisma migrate deploy",
    "db:seed": "cd packages/backend && pnpm prisma db seed",
    "db:studio": "cd packages/backend && pnpm prisma studio"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
