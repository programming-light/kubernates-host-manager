// This is your Prisma schema file for the worker service
// Note: Schema is defined in packages/backend/prisma/schema.prisma
// This file is a copy to allow the worker to be deployed independently

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Users & Authentication =====

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(DEVELOPER)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Relations
  deployments Deployment[]
  auditLogs   AuditLog[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([tenantId])
  @@index([email])
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

// ===== Tenants & Multi-tenancy =====

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  
  // Relations
  users          User[]
  plans          TenantPlan[]
  clusters       Cluster[]
  projects       Project[]
  subscriptions  Subscription[]
  auditLogs      AuditLog[]
  domains        Domain[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([slug])
}

// ===== Plans & Billing =====

model Plan {
  id                String   @id @default(cuid())
  name              String
  type              PlanType @unique
  price             Float
  projectLimit      Int
  deploymentSlots   Int
  storageGB         Int
  bandwidthGB       Int
  features          String[]
  
  // Relations
  tenantPlans       TenantPlan[]
  subscriptions     Subscription[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model TenantPlan {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([tenantId, planId])
  @@index([tenantId])
  @@index([planId])
}

model Subscription {
  id                  String              @id @default(cuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan                @relation(fields: [planId], references: [id], onDelete: Restrict)
  status              SubscriptionStatus  @default(ACTIVE)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelledAt         DateTime?
  
  // Billing
  billingHistory      BillingHistory[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId])
  @@index([tenantId])
  @@index([planId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PENDING
}

model BillingHistory {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String   @default("USD")
  status          String   @default("paid")
  invoiceUrl      String?
  paidAt          DateTime?
  
  createdAt DateTime @default(now())
  
  @@index([subscriptionId])
}

// ===== Kubernetes Clusters =====

model Cluster {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  provider        ClusterProvider
  region          String
  status          ClusterStatus   @default(ACTIVE)
  
  // Credentials (encrypted)
  apiEndpoint     String
  caCertificate   String
  clientCert      String
  clientKey       String
  token           String?
  
  // Relations
  projects        Project[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId, name])
  @@index([tenantId])
}

enum ClusterProvider {
  EKS
  GKE
  AKS
  DIGITAL_OCEAN
  CUSTOM
}

enum ClusterStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// ===== Projects & Deployments =====

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clusterId   String
  cluster     Cluster  @relation(fields: [clusterId], references: [id], onDelete: Restrict)
  
  name        String
  slug        String
  description String?
  gitUrl      String
  namespace   String
  status      ProjectStatus @default(ACTIVE)
  
  // Relations
  deployments   Deployment[]
  environments  Environment[]
  domains       Domain[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([clusterId])
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model Deployment {
  id            String              @id @default(cuid())
  projectId     String
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version       Int
  status        DeploymentStatus    @default(QUEUED)
  
  commitSha     String
  commitMessage String?
  deployedBy    String
  deployedByUser User               @relation(fields: [deployedBy], references: [id], onDelete: SetNull)
  
  logs          String?
  
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  
  @@unique([projectId, version])
  @@index([projectId])
  @@index([status])
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYING
  RUNNING
  FAILED
  ROLLED_BACK
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String   @default("default")
  variables String   // JSON stringified Record<string, string>
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([projectId, name])
  @@index([projectId])
}

// ===== Domains & SSL =====

model Domain {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  domain      String
  status      DomainStatus @default(PENDING)
  dnsRecord   String?
  
  // SSL Certificate
  certificates SSLCertificate[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId, domain])
  @@index([tenantId])
  @@index([projectId])
}

enum DomainStatus {
  PENDING
  VERIFIED
  ERROR
}

model SSLCertificate {
  id        String   @id @default(cuid())
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  provider  String   @default("letsencrypt")
  issuer    String?
  expiresAt DateTime
  status    String   @default("active")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([domainId])
}

// ===== Audit Logging =====

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action        String   // e.g., "deployment.created", "project.updated"
  resourceType  String   // e.g., "deployment", "project"
  resourceId    String
  changes       String   // JSON stringified changes
  
  ipAddress     String?
  userAgent     String?
  
  createdAt DateTime @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

// ===== Feature Flags =====

model FeatureFlag {
  id        String   @id @default(cuid())
  name      String   @unique
  enabled   Boolean  @default(false)
  value     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
