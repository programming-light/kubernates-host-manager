# Server
PORT=3001
NODE_ENV=development

# Client
CLIENT_URL=http://localhost:3000

# Public Client URL (marketing site)
PUBLIC_CLIENT_URL=http://localhost:3002

# Server URL
SERVER_URL=http://localhost:3001

# API URL (used by Next.js apps)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Default domain suffix for project preview URLs (used by client)
# Should match server's DEFAULT_DOMAIN_SUFFIX
NEXT_PUBLIC_DOMAIN_SUFFIX=k8s-host.preview

# For GitHub webhooks in dev, use ngrok: ngrok http 3001
# Then set API_URL to your ngrok URL (e.g. https://abc123.ngrok.io)
# API_URL=

# Redis (for queue and OTP cache)
# Local: redis://localhost:6379
# Upstash: redis://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/k8s_platform

# Authentication
JWT_SECRET=change-me-to-a-random-secret
REFRESH_SECRET=change-me-to-another-random-secret
accessTokenExp="15d"
refreshTokenExp="30d"

# ============================================
# KUBERNETES CONFIGURATION
# ============================================

# Default Kubernetes Provider
# Options: minikube, kind, k3s, k3d, docker-desktop, microk8s, kubeadm, rancher, custom
K8S_PROVIDER=minikube

# ============================================
# MINIKUBE (Docker Driver)
# ============================================
MINIKUBE_KUBECONFIG=~/.kube/config
MINIKUBE_TOKEN=
MINIKUBE_CA_CERT=

# ============================================
# KIND (Kubernetes in Docker)
# ============================================
KIND_CLUSTER_NAME=kubernetes-host-manager
KIND_KUBECONFIG=~/.kube/config

# ============================================
# K3S (Lightweight Kubernetes)
# ============================================
K3S_URL=https://localhost:6443
K3S_TOKEN=
K3S_CA_CERT=
K3S_KUBECONFIG=~/.kube/config

# ============================================
# K3D (K3s in Docker)
# ============================================
K3D_CLUSTER_NAME=k8s-platform
K3D_KUBECONFIG=~/.kube/config

# ============================================
# DOCKER DESKTOP KUBERNETES
# ============================================
DOCKER_DESKTOP_KUBECONFIG=~/.kube/config

# ============================================
# MICROK8S
# ============================================
MICROK8S_KUBECONFIG=~/.kube/config

# ============================================
# RANCHER
# ============================================
RANCHER_URL=
RANCHER_TOKEN=
RANCHER_CLUSTER_ID=

# ============================================
# KUBEADM (Bare Metal)
# ============================================
KUBEADM_API_SERVER=
KUBEADM_CA_CERT=
KUBEADM_TOKEN=
KUBEADM_NODE_NAME=

# ============================================
# CUSTOM / BARE METAL
# ============================================
CUSTOM_K8S_API_SERVER=
CUSTOM_K8S_CA_CERT=
CUSTOM_K8S_CLIENT_CERT=
CUSTOM_K8S_CLIENT_KEY=
CUSTOM_K8S_TOKEN=
CUSTOM_K8S_NAMESPACE=default

# ============================================
# AWS EKS
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EKS_CLUSTER_NAME=
EKS_KUBECONFIG=~/.kube/config

# ============================================
# GOOGLE GKE
# ============================================
GCP_PROJECT_ID=
GCP_REGION=us-central1
GKE_CLUSTER_NAME=
GKE_SERVICE_ACCOUNT_KEY=

# ============================================
# AZURE AKS
# ============================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AKS_CLUSTER_NAME=

# ============================================
# KUBERNETES SETTINGS
# ============================================
DEFAULT_NAMESPACE=default
K8S_REQUEST_TIMEOUT=60000
K8S_CONNECT_TIMEOUT=30000
K8S_SKIP_TLS_VERIFY=false

# ============================================
# DEFAULT DOMAIN FOR PROJECT PREVIEWS
# ============================================
# Base domain suffix for auto-generated preview URLs (like Vercel's .vercel.app)
# Each deployed project gets {slug}.{DEFAULT_DOMAIN_SUFFIX}
# For local/dev: use sslip.io or nip.io (e.g., "192.168.1.100.sslip.io")
# For production: use a real wildcard domain (e.g., "k8s-host.com")
DEFAULT_DOMAIN_SUFFIX=k8s-host.preview

# ============================================
# GITHUB OAUTH
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# ============================================
# SMTP (Email)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ============================================
# PAYMENT GATEWAYS
# ============================================
SERVER_URL=http://localhost:3001

# SSLCommerz
SSL_COMMERZ_STORE_ID=
SSL_COMMERZ_STORE_PASS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
