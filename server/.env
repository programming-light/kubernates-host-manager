# Server
PORT=3001
NODE_ENV=development

# Client
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://neondb_owner:npg_Ek0rO4veXxjo@ep-blue-scene-a1t3umeo-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
accessTokenExp="15d"
refreshTokenExp="30d"

# ============================================
# KUBERNETES CONFIGURATION
# ============================================

# Default Kubernetes Provider
# Options: minikube, kind, k3s, k3d, docker-desktop, microk8s, kubeadm, rancher, custom
K8S_PROVIDER=minikube

# ============================================
# MINIKUBE (Docker Driver)
# ============================================
# For Docker driver, use kubeconfig (recommended)
# The kubeconfig already has correct server and certificates
MINIKUBE_KUBECONFIG=~/.kube/config
# Token and CA cert are optional - kubeconfig is preferred
MINIKUBE_TOKEN=
MINIKUBE_CA_CERT=

# ============================================
# KIND (Kubernetes in Docker)
# ============================================
KIND_CLUSTER_NAME=kubernetes-host-manager
KIND_KUBECONFIG=~/.kube/config

# ============================================
# K3S (Lightweight Kubernetes)
# ============================================
K3S_URL=https://localhost:6443
K3S_TOKEN=
K3S_CA_CERT=
K3S_KUBECONFIG=~/.kube/config

# ============================================
# K3D (K3s in Docker)
# ============================================
K3D_CLUSTER_NAME=k8s-platform
K3D_KUBECONFIG=~/.kube/config

# ============================================
# DOCKER DESKTOP KUBERNETES
# ============================================
DOCKER_DESKTOP_KUBECONFIG=~/.kube/config

# ============================================
# MICROK8S
# ============================================
MICROK8S_KUBECONFIG=~/.kube/config

# ============================================
# RANCHER
# ============================================
RANCHER_URL=
RANCHER_TOKEN=
RANCHER_CLUSTER_ID=

# ============================================
# KUBEADM (Bare Metal)
# ============================================
KUBEADM_API_SERVER=
KUBEADM_CA_CERT=
KUBEADM_TOKEN=
KUBEADM_NODE_NAME=

# ============================================
# CUSTOM / BARE METAL
# ============================================
CUSTOM_K8S_API_SERVER=
CUSTOM_K8S_CA_CERT=
CUSTOM_K8S_CLIENT_CERT=
CUSTOM_K8S_CLIENT_KEY=
CUSTOM_K8S_TOKEN=
CUSTOM_K8S_NAMESPACE=default

# ============================================
# AWS EKS
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EKS_CLUSTER_NAME=
EKS_KUBECONFIG=~/.kube/config

# ============================================
# GOOGLE GKE
# ============================================
GCP_PROJECT_ID=
GCP_REGION=us-central1
GKE_CLUSTER_NAME=
GKE_SERVICE_ACCOUNT_KEY=

# ============================================
# AZURE AKS
# ============================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AKS_CLUSTER_NAME=

# ============================================
# KUBERNETES SETTINGS
# ============================================
DEFAULT_NAMESPACE=default
K8S_REQUEST_TIMEOUT=60000
K8S_CONNECT_TIMEOUT=30000
K8S_SKIP_TLS_VERIFY=true

# ============================================
# PAYMENT GATEWAYS
# ============================================
SERVER_URL=http://localhost:3001

# SSLCommerz
SSL_COMMERZ_STORE_ID=
SSL_COMMERZ_STORE_PASS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
