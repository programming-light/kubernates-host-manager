# Database
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/k8s_platform

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encryption (for storing cluster credentials and sensitive data)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here-generated-by-openssl

# Backend
BACKEND_URL=http://localhost:3001
BACKEND_PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Worker
WORKER_PORT=3002

# Stripe (optional, for billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Kubernetes Configuration
KUBECONFIG=/path/to/kubeconfig.yaml

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@k8s-platform.local

# Sentry (optional, for error tracking)
SENTRY_DSN=

# Pricing & Billing
# Plans configuration - can be managed via admin API
# Default plan for new workspaces (use slug from database)
DEFAULT_PLAN_SLUG=starter

# ISR Revalidation time in seconds (for pricing page)
# Pricing page updates every N seconds with latest plan data
NEXT_PUBLIC_ISR_REVALIDATION=300

# Feature Flags
ENABLE_BILLING=true
ENABLE_ADMIN_PANEL=true
ENABLE_AUDIT_LOGS=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
