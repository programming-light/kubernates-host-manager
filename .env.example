# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database (optional - currently using in-memory storage)
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/k8s_platform

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# ============================================
# EMAIL / SMTP CONFIGURATION
# ============================================
# SMTP Provider: Gmail, Outlook, custom SMTP server
# For Gmail: Use App Password (not your regular password)
#   - Enable 2FA on your Google account
#   - Go to: https://myaccount.google.com/apppasswords
#   - Generate an App Password for "Mail"
#   - Use that 16-character app password as SMTP_PASS

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM="K8s Platform" <noreply@k8splatform.com>

# For Outlook/Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For custom SMTP server:
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true

# ============================================
# KUBERNETES CONFIGURATION
# ============================================

# Provider: minikube, kind, k3s, k3d, docker-desktop, microk8s, kubeadm, rancher, eks, gke, aks, custom
K8S_PROVIDER=minikube

# Default namespace for K8s operations
DEFAULT_NAMESPACE=default

# Request timeouts (milliseconds)
K8S_REQUEST_TIMEOUT=30000
K8S_CONNECT_TIMEOUT=10000

# Skip TLS verification (not recommended for production)
K8S_SKIP_TLS_VERIFY=false

# ============================================
# MINIKUBE (Docker Driver)
# ============================================
# For Docker driver, use kubeconfig (recommended)
# The kubeconfig has correct server, port, and certificates
MINIKUBE_KUBECONFIG=~/.kube/config
# Token and CA cert are optional - kubeconfig is preferred
MINIKUBE_TOKEN=
MINIKUBE_CA_CERT=

# Skip TLS verification (recommended for local dev)
K8S_SKIP_TLS_VERIFY=true

# ============================================
# KIND (Kubernetes in Docker)
# ============================================
KIND_CLUSTER_NAME=kubernetes-host-manager
KIND_KUBECONFIG=~/.kube/config

# ============================================
# K3S (Lightweight Kubernetes)
# ============================================
# Get token with: sudo cat /var/lib/rancher/k3s/server/node-token
K3S_URL=https://localhost:6443
K3S_TOKEN=
K3S_CA_CERT=
K3S_KUBECONFIG=~/.kube/config

# ============================================
# K3D (K3s in Docker)
# ============================================
K3D_CLUSTER_NAME=k8s-platform
K3D_KUBECONFIG=~/.kube/config

# ============================================
# DOCKER DESKTOP KUBERNETES
# ============================================
DOCKER_DESKTOP_KUBECONFIG=~/.kube/config

# ============================================
# MICROK8S
# ============================================
MICROK8S_KUBECONFIG=~/.kube/config

# ============================================
# KUBEADM (Bare Metal / Custom)
# ============================================
# Get token with: kubeadm token list
KUBEADM_API_SERVER=https://your-server-ip:6443
KUBEADM_CA_CERT=<base64-encoded-ca-cert>
KUBEADM_TOKEN=<bootstrap-token-from-kubeadm>
KUBEADM_NODE_NAME=worker-1

# ============================================
# RANCHER
# ============================================
RANCHER_URL=https://your-rancher.com
RANCHER_TOKEN=<rancher-api-token>
RANCHER_CLUSTER_ID=local

# ============================================
# AWS EKS
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EKS_CLUSTER_NAME=my-cluster
EKS_KUBECONFIG=~/.kube/config

# ============================================
# GOOGLE GKE
# ============================================
GCP_PROJECT_ID=my-project
GCP_REGION=us-central1
GKE_CLUSTER_NAME=my-cluster
GKE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json

# ============================================
# AZURE AKS
# ============================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AKS_CLUSTER_NAME=my-cluster

# ============================================
# CUSTOM / BARE METAL CLUSTER
# ============================================
# Use this for any standard Kubernetes cluster
CUSTOM_K8S_API_SERVER=https://your-cluster:6443
CUSTOM_K8S_CA_CERT=<base64-encoded-ca-cert>
CUSTOM_K8S_CLIENT_CERT=<base64-encoded-client-cert>
CUSTOM_K8S_CLIENT_KEY=<base64-encoded-client-key>
CUSTOM_K8S_TOKEN=<bearer-token>
CUSTOM_K8S_NAMESPACE=default

# ============================================
# PAYMENT GATEWAYS
# ============================================
SERVER_URL=http://localhost:3001

# SSLCommerz (Bangladesh)
SSL_COMMERZ_STORE_ID=your_store_id
SSL_COMMERZ_STORE_PASS=your_store_password

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
